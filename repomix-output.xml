 902: int CVICALLBACK AdcStrictDiagnosticCB (int p, int c, int ev, void *cbd, int e1, int e2)
 903: {
 904:     if (ev != EVENT_COMMIT) return 0;
 905:     I16  err;
 906:     U16  testCard;
 907:     U16  chans[2] = {0, 1};
 908:     U16  bufId;
 909:     U32  testSamplesPerCh = 2048;
 910:     U32  testTotalSamples = testSamplesPerCh * 2 * 2;
 911:     U16 *testBuffer = NULL;
 912:     BOOLEAN halfReady, stopFlag;
 913:     int  buffersProcessed = 0;
 914:     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "DIAG: Registering...");
 915:     ProcessSystemEvents();
 916:     testCard = WD_Register_Card(PCI_9846H, 0);
 917:     if (testCard < 0) {
 918:         MessagePopup("DIAG ERROR", "Failed to register card.");
 919:         return 0;
 920:     }
 921:     WD_AI_Config(testCard, WD_IntTimeBase, 0, WD_AI_ADCONVSRC_TimePacer, 0, 1);
 922:     WD_AI_CH_Config(testCard, 0, AD_B_1_V);
 923:     WD_AI_CH_Config(testCard, 1, AD_B_1_V);
 924:     err = WD_AI_Trig_Config(testCard, WD_AI_TRGMOD_POST, WD_AI_TRGSRC_ExtD, WD_AI_TrgPositive, 0, 0.0, 0, 0, 0, 1);
 925:     testBuffer = (U16 *)WD_Buffer_Alloc(testCard, testTotalSamples * sizeof(U16));
 926:     if (!testBuffer) {
 927:         WD_Release_Card(testCard);
 928:         MessagePopup("DIAG ERROR", "WD_Buffer_Alloc failed.");
 929:         return 0;
 930:     }
 931:     WD_AI_ContBufferReset(testCard);
 932:     err = WD_AI_ContBufferSetup(testCard, testBuffer, testTotalSamples, &bufId);
 933:     err = WD_AI_AsyncDblBufferMode(testCard, 1);
 934:     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "DIAG: Waiting for Trigger...");
 935:     ProcessSystemEvents();
 936:     err = WD_AI_ContReadMultiChannels(testCard, 2, chans, bufId, testSamplesPerCh, 1, 1, ASYNCH_OP);
 937:     if (err != NoError) {
 938:         char msg[128];
 939:         sprintf(msg, "DIAG FAILED at Execution: %d", err);
 940:         MessagePopup("IOCTL Error", msg);
 941:     } else {
 942:         while (buffersProcessed < 4) {
 943:             WD_AI_AsyncDblBufferHalfReady(testCard, &halfReady, &stopFlag);
 944:             if (halfReady) {
 945:                 WD_AI_AsyncDblBufferHandled(testCard);
 946:                 buffersProcessed++;
 947:                 char msg[64];
 948:                 sprintf(msg, "DIAG: Processed Buffer %d/4", buffersProcessed);
 949:                 SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, msg);
 950:                 ProcessSystemEvents();
 951:             }
 952:             if (stopFlag) break;
 953:         }
 954:         MessagePopup("DIAG SUCCESS", "Hardware successfully streamed 4 half-buffers.");
 955:     }
 956:     WD_AI_AsyncClear(testCard, NULL, NULL);
 957:     WD_AI_AsyncDblBufferMode(testCard, 0);
 958:     WD_AI_ContBufferReset(testCard);
 959:     WD_Buffer_Free(testCard, testBuffer);
 960:     WD_Release_Card(testCard);
 961:     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "DIAG: Complete and Released.");
 962:     return 0;
 963: }
