 811: int CVICALLBACK DdsStartCB (int p, int c, int ev, void *cbd, int e1, int e2)
 812: {
 813:     double startF, stopF, period, cwFreq;
 814:     double actStart, actStop, actPeriod, actCW;
 815:     int    chirpMode;
 816:     uint32_t rampFlags;
 817:     char   msg[256];
 818:     if (ev != EVENT_COMMIT) return 0;
 819:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_RING_CHIRP_MODE, &chirpMode);
 820:     if (chirpMode == 2)
 821:     {
 822:         GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_CW_FREQ, &cwFreq);
 823:         if (!dds_reset ()) { return 0; }
 824:         if (!dds_powerup ()) { return 0; }
 825:         Delay(0.01);
 826:         if (!ad9914_calibrate_dac ()) { return 0; }
 827:         if (!ad9914_single_tone (cwFreq, &actCW)) { return 0; }
 828:         if (!dds_update ()) { return 0; }
 829:         ddsSweepActive = 1;
 830:         lastActualPeriod_us = 0.0;
 831:         sprintf (msg, "CW output: %.6f MHz (requested %.6f MHz)", actCW, cwFreq);
 832:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_STATUS, msg);
 833:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_START,  actCW);
 834:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_STOP,   0.0);
 835:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_PERIOD, 0.0);
 836:     }
 837:     else
 838:     {
 839:         GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_START_FREQ, &startF);
 840:         GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_STOP_FREQ,  &stopF);
 841:         GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_PERIOD,      &period);
 842:         if (startF == stopF)
 843:         {
 844:             SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_STATUS, "ERROR: Start/Stop frequencies cannot match in Sweep Mode");
 845:             return 0;
 846:         }
 847:         if (!dds_reset ()) { return 0; }
 848:         if (!dds_powerup ()) { return 0; }
 849:         Delay(0.01);
 850:         if (!ad9914_calibrate_dac ()) { return 0; }
 851:         if (chirpMode == 0)
 852:         {
 853:             rampFlags = DRG_NO_DWELL_HIGH;
 854:             if (!dds_drctrl (0))
 855:             {
 856:                 SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_STATUS, "DRCTRL config FAILED");
 857:                 return 0;
 858:             }
 859:         }
 860:         else
 861:         {
 862:             rampFlags = DRG_NO_DWELL;
 863:         }
 864:         if (!ad9914_ramp_generator (startF, stopF, period, rampFlags,
 865:                                     &actStart, &actStop, &actPeriod))
 866:         {
 867:             SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_STATUS, "Ramp config FAILED");
 868:             return 0;
 869:         }
 870:         if (!dds_update ()) { return 0; }
 871:         ddsSweepActive = 1;
 872:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_START,  actStart);
 873:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_STOP,   actStop);
 874:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ACT_PERIOD, actPeriod);
 875:         lastActualPeriod_us = actPeriod;
 876:         DDS_UpdateTimingDisplay ();
 877:         sprintf (msg, "%s sweep  (%.6f to %.6f MHz, %.3f us)",
 878:                  (chirpMode == 0) ? "Triggered" : "Free-run",
 879:                  actStart, actStop, actPeriod);
 880:         SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_STATUS, msg);
 881:     }
 882:     SetCtrlAttribute (ddsTabHandle, TABPANEL_DDS_BTN_START, ATTR_DIMMED, 1);
 883:     SetCtrlAttribute (ddsTabHandle, TABPANEL_DDS_BTN_STOP,  ATTR_DIMMED, 0);
 884:     return 0;
 885: }
