 256:     s = viWrite (psuSession, (ViBuf)buf, (ViUInt32)strlen(buf), &retCnt);
 257:     if (s < VI_SUCCESS) return -1;
 258:     memset (resp, 0, maxLen);
 259:     s = viRead (psuSession, (ViBuf)resp, (ViUInt32)(maxLen-1), &retCnt);
 260:     if (s < VI_SUCCESS && s != VI_SUCCESS_TERM_CHAR && s != VI_SUCCESS_MAX_CNT) return -1;
 261:     while (retCnt > 0 && (resp[retCnt-1]=='\n'||resp[retCnt-1]=='\r'||resp[retCnt-1]==' '))
 262:         resp[--retCnt] = '\0';
 263:     return 0;
 264: }
