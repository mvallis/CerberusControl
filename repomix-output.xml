 278: static int NextPow2 (int v)
 279: {
 280:     int p = 1;
 281:     while (p < v) p <<= 1;
 282:     return p;
 283: }
 284: static void FFT_Radix2 (double *re, double *im, int n)
 285: {
 286:     int i, j, k, m, step;
 287:     double tr, ti, wr, wi, wpr, wpi, theta;
 288:     j = 0;
 289:     for (i = 0; i < n - 1; i++) {
 290:         if (i < j) {
 291:             tr = re[j]; re[j] = re[i]; re[i] = tr;
 292:             ti = im[j]; im[j] = im[i]; im[i] = ti;
 293:         }
 294:         m = n >> 1;
 295:         while (m >= 1 && j >= m) { j -= m; m >>= 1; }
 296:         j += m;
 297:     }
 298:     for (step = 2; step <= n; step <<= 1) {
 299:         theta = -2.0 * PI / (double)step;
 300:         wpr = cos(theta);
 301:         wpi = sin(theta);
 302:         wr = 1.0; wi = 0.0;
 303:         for (k = 0; k < step / 2; k++) {
 304:             for (i = k; i < n; i += step) {
 305:                 j = i + step / 2;
 306:                 tr = wr * re[j] - wi * im[j];
 307:                 ti = wr * im[j] + wi * re[j];
 308:                 re[j] = re[i] - tr;
 309:                 im[j] = im[i] - ti;
 310:                 re[i] += tr;
 311:                 im[i] += ti;
 312:             }
 313:             tr = wr;
 314:             wr = tr * wpr - wi * wpi;
 315:             wi = tr * wpi + wi * wpr;
 316:         }
 317:     }
 318: }
 319: int CVICALLBACK DiskWriterThreadFunction (void *functionData)
 320: {
 321:     U16 *localBuf = malloc(halfBufferSize * sizeof(U16));
 322:     static int writeCounter = 0;
 323:     if (!localBuf) return -1;
 324:     while (isAcquiring) {
 325:         int itemsRead = CmtReadTSQData(dmaQueue, localBuf, 1, 100, 0);
 326:         if (itemsRead > 0) {
 327:             if (recordFile != NULL) {
 328:                 fwrite(localBuf, sizeof(U16), halfBufferSize, recordFile);
 329:                 recordedTrigs += (halfBufferSize / ADC_NUM_CHANNELS) / samplesPerChirp;
 330:                 writeCounter++;
 331:                 if (writeCounter % 10 == 0) {
 332:                     char msg[64];
 333:                     sprintf(msg, "Disk Write: %d blocks", writeCounter);
 334:                     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, msg);
 335:                 }
 336:             }
 337:             if (!plotBusy && samplesPerChirp > 0 && currentProgDiv > 0) {
 338:                 U32 halfSamplesPerCh = halfBufferSize / ADC_NUM_CHANNELS;
 339:                 U32 startPhase = absoluteSampleCount % currentProgDiv;
 340:                 U32 offsetToFirstChirp = (startPhase == 0) ? 0 : (currentProgDiv - startPhase);
 341:                 if (halfSamplesPerCh > (offsetToFirstChirp + samplesPerChirp)) {
 342:                     U32 n_max = (halfSamplesPerCh - samplesPerChirp - offsetToFirstChirp) / currentProgDiv;
 343:                     U32 lastChirpStart = offsetToFirstChirp + (n_max * currentProgDiv);
 344:                     U32 bufferOffset = lastChirpStart * ADC_NUM_CHANNELS;
 345:                     plotBusy = 1;
 346:                     memcpy(plotBuffer, localBuf + bufferOffset, samplesPerChirp * ADC_NUM_CHANNELS * sizeof(U16));
 347:                     plotSamples = samplesPerChirp;
 348:                     PostDeferredCall((DeferredCallbackPtr)ADC_PlotFFT_Deferred, NULL);
 349:                 }
 350:             }
 351:             absoluteSampleCount += (halfBufferSize / ADC_NUM_CHANNELS);
 352:         }
 353:     }
 354:     while (CmtReadTSQData(dmaQueue, localBuf, 1, 0, 0) > 0) {
 355:         if (recordFile) fwrite(localBuf, sizeof(U16), halfBufferSize, recordFile);
 356:     }
 357:     if (recordFile) fflush(recordFile);
 358:     free(localBuf);
 359:     return 0;
 360: }
 361: void CVICALLBACK Overrun_Deferred (void *callbackData) {
 362:     int overrunType = (int)(intptr_t)callbackData;
 363:     if (overrunType == 1) {
 364:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "HALTED: DMA Queue Full (Disk IO too slow)");
 365:     } else {
 366:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "HALTED: Hardware DMA Overrun");
 367:     }
 368:     AdcStopCB(0, 0, EVENT_COMMIT, NULL, 0, 0);
 369: }
 370: int CVICALLBACK HardwarePollThreadFunction (void *functionData)
 371: {
 372:     BOOLEAN halfReady, fStop;
 373:     int activeBuf = 0;
 374:     int queueStatus;
 375:     while (isAcquiring) {
 376:         WD_AI_AsyncDblBufferHalfReady(adcCard, &halfReady, &fStop);
 377:         if (halfReady) {
 378:             U16 *src = (activeBuf == 0) ? dmaBuffer1 : dmaBuffer2;
 379:             queueStatus = CmtWriteTSQData(dmaQueue, src, 1, 0, NULL);
 380:             if (queueStatus < 0 && isAcquiring) {
 381:                 PostDeferredCall((DeferredCallbackPtr)Overrun_Deferred, (void*)1);
 382:                 break;
 383:             }
 384:             activeBuf = 1 - activeBuf;
 385:             heartbeatCounter++;
 386:         }
 387:         if (fStop && isAcquiring) {
 388:             PostDeferredCall((DeferredCallbackPtr)Overrun_Deferred, (void*)0);
 389:             break;
 390:         }
 391:         Sleep(1);
 392:     }
 393:     return 0;
 394: }
 395: void CVICALLBACK ADC_PlotFFT_Deferred (void *callbackData)
 396: {
 397:     U32 fftN;
 398:     int plotN;
 399:     int i;
 400:     double startF, stopF, bwDDS_Hz, bwTx_Hz, chirpPeriod_s;
 401:     double rangePerBin;
 402:     if (plotSamples == 0) {
 403:         plotBusy = 0;
 404:         return;
 405:     }
 406:     for (i = 0; i < plotSamples; i++) {
 407:         double raw0 = (double)((int)plotBuffer[i * ADC_NUM_CHANNELS] - 32768);
 408:         double raw1 = (double)((int)plotBuffer[i * ADC_NUM_CHANNELS + 1] - 32768);
 409:         timeDataCH0[i] = (raw0 / 32768.0) * currentAdcVoltageLimit;
 410:         timeDataCH1[i] = (raw1 / 32768.0) * currentAdcVoltageLimit;
 411:     }
 412:     DeleteGraphPlot (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, -1, VAL_IMMEDIATE_DRAW);
 413:     {
 414:         int hT0, hT1;
 415:         hT0 = PlotY (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, timeDataCH0, plotSamples,
 416:                VAL_DOUBLE, VAL_THIN_LINE, VAL_NO_POINT, VAL_SOLID, 1, VAL_YELLOW);
 417:         hT1 = PlotY (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, timeDataCH1, plotSamples,
 418:                VAL_DOUBLE, VAL_THIN_LINE, VAL_NO_POINT, VAL_SOLID, 1, VAL_CYAN);
 419:         SetPlotAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, hT0, ATTR_PLOT_LG_TEXT, "LRX");
 420:         SetPlotAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, hT1, ATTR_PLOT_LG_TEXT, "URX");
 421:         SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_TIME, ATTR_LEGEND_VISIBLE, 1);
 422:     }
 423:     ADC_ComputeFFT (plotBuffer, plotSamples, 0, ADC_NUM_CHANNELS, fftMagCH0);
 424:     ADC_ComputeFFT (plotBuffer, plotSamples, 1, ADC_NUM_CHANNELS, fftMagCH1);
 425:     fftN  = (U32)NextPow2 (plotSamples);
 426:     plotN = (int)(fftN / 2);
 427:     if (plotN > FFT_MAX_SIZE / 2) plotN = FFT_MAX_SIZE / 2;
 428:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_START_FREQ, &startF);
 429:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_STOP_FREQ,  &stopF);
 430:     bwDDS_Hz = fabs(stopF - startF) * 1e6;
 431:     bwTx_Hz  = (double)FREQ_MULTIPLIER * bwDDS_Hz;
 432:     chirpPeriod_s = (lastActualPeriod_us > 0.0) ? lastActualPeriod_us * 1e-6 : 1.0;
 433:     if (bwTx_Hz > 0.0 && currentAdcSampleRateHz > 0.0) {
 434:         rangePerBin = (SPEED_OF_LIGHT * currentAdcSampleRateHz * chirpPeriod_s)
 435:                       / (2.0 * (double)fftN * bwTx_Hz);
 436:     } else {
 437:         rangePerBin = 1.0;
 438:     }
 439:     for (i = 0; i < plotN; i++) {
 440:         rangeAxis[i] = (double)i * rangePerBin;
 441:     }
 442:     DeleteGraphPlot (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, -1, VAL_IMMEDIATE_DRAW);
 443:     {
 444:         int hF0, hF1;
 445:         hF0 = PlotXY (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, rangeAxis, fftMagCH0, plotN,
 446:                 VAL_DOUBLE, VAL_DOUBLE, VAL_THIN_LINE, VAL_NO_POINT, VAL_SOLID, 1, VAL_YELLOW);
 447:         hF1 = PlotXY (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, rangeAxis, fftMagCH1, plotN,
 448:                 VAL_DOUBLE, VAL_DOUBLE, VAL_THIN_LINE, VAL_NO_POINT, VAL_SOLID, 1, VAL_CYAN);
 449:         SetPlotAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, hF0, ATTR_PLOT_LG_TEXT, "LRX");
 450:         SetPlotAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, hF1, ATTR_PLOT_LG_TEXT, "URX");
 451:         SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, ATTR_LEGEND_VISIBLE, 1);
 452:         SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, ATTR_XNAME, "Range (m)");
 453:         SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_GRAPH_FFT, ATTR_YNAME, "Magnitude (dB)");
 454:     }
 455:     plotBusy = 0;
 456: }
 457: static void ADC_ComputeFFT (U16 *data, int nSamples, int chOffset, int nCh,
 458:                             double *outMag)
 459: {
 460:     int i, fftN;
 461:     fftN = NextPow2 (nSamples);
 462:     if (fftN > FFT_MAX_SIZE) fftN = FFT_MAX_SIZE;
 463:     memset (fftReal, 0, sizeof(double) * fftN);
 464:     memset (fftImag, 0, sizeof(double) * fftN);
 465:     for (i = 0; i < nSamples && i < fftN; i++)
 466:     {
 467:         double raw = (double)((int)data[i * nCh + chOffset] - 32768);
 468:         double win = 0.5 * (1.0 - cos(2.0 * PI * (double)i / (double)(nSamples - 1)));
 469:         fftReal[i] = raw * win;
 470:     }
 471:     FFT_Radix2 (fftReal, fftImag, fftN);
 472:     for (i = 0; i < fftN / 2; i++)
 473:     {
 474:         double mag = sqrt (fftReal[i] * fftReal[i] + fftImag[i] * fftImag[i]);
 475:         outMag[i] = (mag > 0.0) ? 20.0 * log10(mag) : -200.0;
 476:     }
 477: }
 478: static int ADC_SaveRawFile (const char *path)
 479: {
 480:     FILE *fp;
 481:     RadarFileHeader hdr;
 482:     U32 sampPerTrig;
 483:     double startF, stopF, period, sampleRate;
 484:     if (plotSamples == 0) return -1;
 485:     GetCtrlVal (adcTabHandle, TABPANEL_2_ADC_NUM_SAMP_PER_TRIG, &sampPerTrig);
 486:     sampleRate = currentAdcSampleRateHz;
 487:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_START_FREQ, &startF);
 488:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_STOP_FREQ,  &stopF);
 489:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_PERIOD,     &period);
 490:     memset (&hdr, 0, sizeof(hdr));
 491:     hdr.magic               = RADAR_FILE_MAGIC;
 492:     hdr.num_channels        = ADC_NUM_CHANNELS;
 493:     hdr.samples_per_trigger = plotSamples;
 494:     hdr.num_triggers        = 1;
 495:     hdr.sample_rate_hz      = sampleRate;
 496:     hdr.dds_start_freq_hz   = startF * 1e6;
 497:     hdr.dds_stop_freq_hz    = stopF  * 1e6;
 498:     hdr.dds_sweep_period_us = period;
 499:     fp = fopen (path, "wb");
 500:     if (fp == NULL) return -1;
 501:     fwrite (&hdr, sizeof(hdr), 1, fp);
 502:     fwrite (plotBuffer, sizeof(U16), plotSamples * ADC_NUM_CHANNELS, fp);
 503:     fclose (fp);
 504:     return 0;
 505: }
