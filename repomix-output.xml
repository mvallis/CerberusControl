 709: static void DDS_UpdateTimingDisplay (void)
 710: {
 711:     double clockMHz, syncClkMHz, syncClkPeriod_us;
 712:     double adcClkMHz, trigFreqHz, drctrlPeriod_us, deadTime_us, calcPeriod_us;
 713:     int    hmcDiv, progDiv, sampsPerChirp;
 714:     int    adcClkDivTotal, chirpSteps, drctrlSteps, minProgDiv, deadSamples;
 715:     char   warnMsg[256];
 716:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_CLOCK_MHZ,       &clockMHz);
 717:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_HMC_DIV,         &hmcDiv);
 718:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_PROG_DIV,        &progDiv);
 719:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_SAMPS_PER_CHI, &sampsPerChirp);
 720:     if (hmcDiv < 2)         hmcDiv = 2;
 721:     if (progDiv < 1)        progDiv = 1;
 722:     if (sampsPerChirp < 1)  sampsPerChirp = 1;
 723:     syncClkMHz       = clockMHz / 24.0;
 724:     syncClkPeriod_us = (syncClkMHz > 0.0) ? 1.0 / syncClkMHz : 0.0;
 725:     adcClkDivTotal = hmcDiv * 2;
 726:     adcClkMHz      = syncClkMHz / (double)adcClkDivTotal;
 727:     currentAdcSampleRateHz = adcClkMHz * 1e6;
 728:     chirpSteps    = sampsPerChirp * adcClkDivTotal;
 729:     calcPeriod_us = (double)chirpSteps * syncClkPeriod_us;
 730:     drctrlSteps     = adcClkDivTotal * progDiv;
 731:     trigFreqHz      = (adcClkMHz > 0.0) ? adcClkMHz * 1e6 / (double)progDiv : 0.0;
 732:     drctrlPeriod_us = (double)drctrlSteps * syncClkPeriod_us;
 733:     deadTime_us = drctrlPeriod_us - lastActualPeriod_us;
 734:     deadSamples = progDiv - sampsPerChirp;
 735:     minProgDiv  = sampsPerChirp + 1;
 736:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_SYNC_CLK,       syncClkMHz);
 737:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_ADC_CLK,        adcClkMHz);
 738:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_TRIG_FREQ,      trigFreqHz);
 739:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_DRCTRL_PERIOD,  drctrlPeriod_us);
 740:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_CHIRP_STEPS,    chirpSteps);
 741:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_CALC_PERIOD,    calcPeriod_us);
 742:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_DEAD_TIME,      deadTime_us);
 743:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_DEAD_SAMPLES,   deadSamples);
 744:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_MIN_PROG_DIV,   minProgDiv);
 745:     warnMsg[0] = '\0';
 746:     if (progDiv <= sampsPerChirp)
 747:     {
 748:         sprintf (warnMsg, "WARNING: Prog divider %d too small! "
 749:                  "Need > %d samples/chirp. No dead time!",
 750:                  progDiv, sampsPerChirp);
 751:     }
 752:     else if (deadTime_us < 0.0 && lastActualPeriod_us > 0.0)
 753:     {
 754:         sprintf (warnMsg, "WARNING: Actual sweep (%.3f us) exceeds "
 755:                  "DRCTRL period (%.3f us). Increase prog divider.",
 756:                  lastActualPeriod_us, drctrlPeriod_us);
 757:     }
 758:     SetCtrlVal (ddsTabHandle, TABPANEL_DDS_MSG_TIMING_WARN, warnMsg);
 759: }
