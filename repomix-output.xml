116: int dds_read_bytes(uint8_t address, int count, uint8_t* data) {
117:     int i;
118:     DWORD written;
119:     DWORD read;
120:     uint8_t value;
121:     char buffer[2 * MAX_DATA_BYTES + 1] = {0};
122:     char command[11];
123:     if ((count < 1) || (count > MAX_DATA_BYTES)) return 0;
124:     sprintf(command, "read,%02x,%x\n", address, count);
125:     WriteFile(sh, command, 10, &written, NULL);
126:     FlushFileBuffers(sh);
127: #ifdef DDS_ENABLE_VERBOSE
128:     printf("==> %s", command);
129: #endif
130:     for (i = 0; i != 2 * MAX_DATA_BYTES + 1; i++) {
131:         char in_char;
132:         if ((!ReadFile(sh, &in_char, 1, &read, NULL)) || (read != 1)) return 0;
133:         buffer[i] = in_char;
134:         if (buffer[i] == '\n') {
135:             buffer[i] = 0;
136:             break;
137:         }
138:         if (i == 2 * MAX_DATA_BYTES) return 0;
139:     }
140: #ifdef DDS_ENABLE_VERBOSE
141:     printf("<== %s\n", buffer);
142: #endif
143:     if (strcmp(buffer, "error") == 0) return 0;
144:     for (i = 0; i != count; i++) {
145:         char in_char = buffer[2 * i];
146:         if ((in_char >= '0') && (in_char <= '9')) value = (uint8_t)(in_char - '0');
147:         else if ((in_char >= 'a') && (in_char <= 'f')) value = (uint8_t)(in_char - 'a' + 10);
148:         else return 0;
149:         in_char = buffer[2 * i + 1];
150:         if ((in_char >= '0') && (in_char <= '9')) data[i] = (uint8_t)((value << 4) + in_char - '0');
151:         else if ((in_char >= 'a') && (in_char <= 'f')) data[i] = (uint8_t)((value << 4) + in_char - 'a' + 10);
152:         else return 0;
153:     }
154:     return 1;
155: }
