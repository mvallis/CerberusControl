279: int ad9914_single_tone(double frequency, double* actual_frequency) {
280:     uint32_t word;
281:     if (frequency > dds_clock) return 0;
282:     word = (uint32_t)(0.5 + 1000000.0 * frequency * POWER_TWO_THIRTYTWO / dds_clock);
283:     if (!dds_write_uint32(0x01, 0x00800900)) return 0;
284:     if (!dds_write_uint32(0x0b, word)) return 0;
285:     if (!dds_write_uint32(0x0c, 0x00000000)) return 0;
286:     if (actual_frequency != NULL)
287:         *actual_frequency = ((double)word) * dds_clock / (1000000.0 * POWER_TWO_THIRTYTWO);
288:     return 1;
289: }
290: int ad9914_ramp_generator(double start_freq, double stop_freq, double period,
291:                           uint32_t flags, double* actual_start,
292:                           double* actual_stop, double* actual_period)
293: {
294:     double steps, round_steps, bandwidth;
295:     uint32_t start_word, step_size, stop_word, cfr2;
296:     if ((stop_freq < start_freq) || (start_freq < 0) ||
297:         (stop_freq > dds_clock) || (period <= 0))
298:         return 0;
299:     steps       = period * dds_clock / (1000000.0 * 24.0);
300:     round_steps = ceil(steps);
301:     bandwidth   = stop_freq * round_steps / steps - start_freq;
302:     start_word  = (uint32_t)(0.5 + 1000000.0 * start_freq *
303:                   POWER_TWO_THIRTYTWO / dds_clock);
304:     step_size   = (uint32_t)(0.5 + (1000000.0 * bandwidth *
305:                   POWER_TWO_THIRTYTWO / dds_clock) / round_steps);
306:     stop_word   = start_word + step_size * ((uint32_t)round_steps);
307:     cfr2 = 0x00082900;
308:     if (flags & DRG_NO_DWELL_LOW)  cfr2 |= (1 << 17);
309:     if (flags & DRG_NO_DWELL_HIGH) cfr2 |= (1 << 18);
310:     if (!dds_write_uint32(0x01, cfr2))           return 0;
311:     if (!dds_write_uint32(0x04, start_word))     return 0;
312:     if (!dds_write_uint32(0x05, stop_word))      return 0;
313:     if (!dds_write_uint32(0x06, step_size))      return 0;
314:     if (!dds_write_uint32(0x07, step_size))      return 0;
315:     if (!dds_write_uint16_pair(0x08, 1, 1))      return 0;
316:     if (!dds_write_uint32(0x09, 0))              return 0;
317:     if (!dds_write_uint32(0x0a, 0))              return 0;
318:     if (actual_start  != NULL)
319:         *actual_start  = ((double)start_word) * dds_clock /
320:                          (1000000.0 * POWER_TWO_THIRTYTWO);
321:     if (actual_stop   != NULL)
322:         *actual_stop   = ((double)stop_word)  * dds_clock /
323:                          (1000000.0 * POWER_TWO_THIRTYTWO);
324:     if (actual_period != NULL)
325:         *actual_period = 1000000.0 * round_steps * 24.0 / dds_clock;
326:     return 1;
327: }
