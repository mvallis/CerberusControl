 1: #include <windows.h>
 2: #include <stdio.h>
 3: #include <conio.h>
 4: #include "wd-dask.h"
 5: #include "wddaskex.h"
 6: #define CHANNELNUMBER 0
 7: #define SCANCOUNT     4000
 8: #define TIMEBASE      WD_IntTimeBase
 9: #define BUFAUTORESET   1
10: #define ADCONVERTSRC  WD_AI_ADCONVSRC_TimePacer
11: #define ADTRIGSRC     WD_AI_TRGSRC_ExtD
12: #define ADTRIGMODE    WD_AI_TRGMOD_POST
13: #define ADTRIGPOL     WD_AI_TrgNegative
14: #define SCAN_INTERVAL  6000
15: short ai_buf[SCANCOUNT];
16: short ai_buf2[SCANCOUNT];
17: FILE *svfile;
18: I16 card;
19: U16 ai_range=0;
20: DAS_IOT_DEV_PROP cardProp;
21: void write_to_file( U16 *buf, U32 write_count )
22: {
23:   U32 i;
24:   F64 vol = 0.0;
25:   for(i=0; i<write_count; i++) {
26: 	WD_AI_VoltScale (card, ai_range, buf[i], &vol);
27:     fprintf( svfile, "0x%04x(%4.2fV)\n", (U16) (buf[i] & cardProp.mask), vol);
28:   }
29: }
30: main()
31: {
32:     I16 err, card_num,i,Id, tmpId = 0;
33:     BOOLEAN halfReady, fStop, fok=0;
34:     U32 count=0, count1, startPos;
35: 	U16 card_type = 1;
36:     printf("This program inputs %d scans from CH-0.\n", SCANCOUNT);
37: 	card_type = WD_ChooseDeviceType(0);
38: 	printf("Please input a card number: ");
39:     scanf(" %hd", &card_num);
40: 	printf("Save data to a file (DmaData.dat): Yes(1) or No(0)? ");
41: 	scanf(" %d", &fok);
42:     if ((card=WD_Register_Card (card_type, card_num)) <0 ) {
43:         printf("Register_Card error=%d", card);
44:         exit(1);
45:     }
46: 	WD_GetDeviceProperties (card, 0, &cardProp);
47: 	ai_range = cardProp.default_range;
48: 	err = WD_AI_CH_Config (card, CHANNELNUMBER, ai_range);
49:     if (err!=NoError) {
50:        printf("WD_AI_CH_Config error=%d", err);
51:        exit(1);
52:     }
53: 	err = WD_AI_Config (card, TIMEBASE, 1, WD_AI_ADCONVSRC_TimePacer, 0, BUFAUTORESET);
54:     if (err!=0) {
55:        printf("WD_AI_Config error=%d", err);
56:        exit(1);
57:     }
58:     err = WD_AI_Trig_Config (card, ADTRIGMODE, ADTRIGSRC, ADTRIGPOL, 0, 0.0, 0, 0, 0, 1);
59:     if (err!=0) {
60:        printf("WD_AI_Trig_Config error=%d", err);
61:        exit(1);
62:     }
63:     err=WD_AI_AsyncDblBufferMode (card, 1);
64:     if (err!=NoError) {
65:        printf("WD_AI_AsyncDblBufferMode error=%d", err);
66:        exit(1);
67:     }
68: 	if(fok) {
69: 		svfile = fopen("DmaData.dat", "w");
70: 		fprintf( svfile, "CH%d :\n", CHANNELNUMBER);
71: 	}
72: 	err=WD_AI_ContBufferSetup (card, ai_buf, SCANCOUNT, &Id);
73: 	err=WD_AI_ContBufferSetup (card, ai_buf2, SCANCOUNT, &Id);
74:     err = WD_AI_ContReadChannel (card, CHANNELNUMBER, Id, SCANCOUNT, SCAN_INTERVAL, SCAN_INTERVAL, ASYNCH_OP);
75:     if (err!=0) {
76:        printf("WD_AI_ContReadChannel error=%d", err);
77:        exit(1);
78:     }
79:     printf("\n\n\nStart Data Conversion by External Trigger Signal\nAnd Press any key to stop Opeartion.\n");
80:     printf("\n\nData count : \n");
81:     do {
82:         do {
83:              WD_AI_AsyncDblBufferHalfReady(card, &halfReady, &fStop);
84: 		} while (!halfReady && !fStop);
85: 	    count += (SCANCOUNT);
86:         printf("%d\r", count);
87: 		if(fok)
88:            write_to_file( tmpId?ai_buf2:ai_buf, SCANCOUNT );
89: 		tmpId = (tmpId + 1) % 2;
90:     } while(!kbhit());
91:     WD_AI_AsyncClear(card, &startPos, &count1);
92: 	if(fok) {
93: 	 write_to_file( tmpId?ai_buf2:ai_buf, count1 );
94:      fclose(svfile);
95: 	}
96: 	printf("\n\nTotal %d input data.\n", count+count1);
97:     WD_Release_Card(card);
98:     printf("\nPress ENTER to exit the program. "); getch();
99: }
</file>

