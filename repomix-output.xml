 984: int CVICALLBACK AdcConfigureCB (int p, int c, int ev, void *cbd, int e1, int e2)
 985: {
 986:     int    rangeIdx, impedIdx, pDiv, i;
 987:     U16    adRange, impedance;
 988:     I16    err;
 989:     char   diagMsg[512];
 990:     U32    targetScans, scansPerHalf, adcTotalSamples;
 991:     if (ev != EVENT_COMMIT || !adcRegistered) return 0;
 992:     GetCtrlVal (adcTabHandle, TABPANEL_2_ADC_RING_RANGE,     &rangeIdx);
 993:     GetCtrlVal (adcTabHandle, TABPANEL_2_ADC_RING_IMPEDANCE, &impedIdx);
 994:     GetCtrlVal (ddsTabHandle, TABPANEL_DDS_NUM_PROG_DIV,     &pDiv);
 995:     adRange = (rangeIdx == 0) ? AD_B_1_V : AD_B_5_V;
 996:     currentAdcVoltageLimit = (rangeIdx == 0) ? 1.0 : 5.0;
 997:     impedance = (impedIdx == 0) ? IMPEDANCE_50Ohm : IMPEDANCE_HI;
 998:     err = WD_AI_Config (adcCard, WD_ExtTimeBase, 1, WD_AI_ADCONVSRC_TimePacer, 0, 1);
 999:     if (err != NoError) {
1000:         sprintf(diagMsg, "AI_Config Error: %d", err);
1001:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, diagMsg);
1002:         return 0;
1003:     }
1004:     for (i = 0; i < ADC_NUM_CHANNELS; i++) {
1005:         WD_AI_CH_Config (adcCard, i, adRange);
1006:         WD_AI_CH_ChangeParam (adcCard, i, AI_IMPEDANCE, impedance);
1007:     }
1008:     if (pDiv <= 0) pDiv = 1;
1009:     samplesPerChirp = 0;
1010:     GetCtrlVal(adcTabHandle, TABPANEL_2_ADC_NUM_SAMP_PER_TRIG, &samplesPerChirp);
1011:     if (samplesPerChirp == 0) samplesPerChirp = 1024;
1012:     targetScans = (U32)(currentAdcSampleRateHz * 0.05);
1013:     if (targetScans < 8192) targetScans = 8192;
1014:     scansPerHalf = ((targetScans / pDiv) + 1) * pDiv;
1015:     halfBufferSize = scansPerHalf * ADC_NUM_CHANNELS;
1016:     adcTotalSamples = halfBufferSize * 2;
1017:     if (dmaBuffer1) { WD_Buffer_Free(adcCard, dmaBuffer1); dmaBuffer1 = NULL; }
1018:     if (dmaBuffer2) { WD_Buffer_Free(adcCard, dmaBuffer2); dmaBuffer2 = NULL; }
1019:     WD_AI_ContBufferReset(adcCard);
1020:     dmaBuffer1 = (U16 *)WD_Buffer_Alloc(adcCard, halfBufferSize * sizeof(U16));
1021:     dmaBuffer2 = (U16 *)WD_Buffer_Alloc(adcCard, halfBufferSize * sizeof(U16));
1022:     if (!dmaBuffer1 || !dmaBuffer2) {
1023:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Memory Allocation Failed");
1024:         return 0;
1025:     }
1026:     err = WD_AI_ContBufferSetup(adcCard, dmaBuffer1, halfBufferSize, &adcBufId);
1027:     err = WD_AI_ContBufferSetup(adcCard, dmaBuffer2, halfBufferSize, &adcBufId);
1028:     WD_AI_AsyncDblBufferMode(adcCard, 1);
1029:     sprintf(diagMsg, "Config OK | Half-Buffer: %lu Samples (~50ms)", (unsigned long)halfBufferSize);
1030:     SetCtrlVal (adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, diagMsg);
1031:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_START_ACQ, ATTR_DIMMED, 0);
1032:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_SINGLE,    ATTR_DIMMED, 0);
1033:     return 0;
1034: }
1035: int CVICALLBACK AdcStartCB (int p, int c, int ev, void *cbd, int e1, int e2)
1036: {
1037:     I16 err;
1038:     U32 totalScansPerCh;
1039:     if (ev != EVENT_COMMIT || !adcRegistered) return 0;
1040:     GetCtrlVal(adcTabHandle, TABPANEL_2_ADC_NUM_SAMP_PER_TRIG, &samplesPerChirp);
1041:     GetCtrlVal(ddsTabHandle, TABPANEL_DDS_NUM_PROG_DIV, &currentProgDiv);
1042:     absoluteSampleCount = 0;
1043:     heartbeatCounter = 0;
1044:     totalScansPerCh = halfBufferSize / ADC_NUM_CHANNELS;
1045:     WD_AI_ContBufferReset(adcCard);
1046:     err = WD_AI_Trig_Config(adcCard, WD_AI_TRGMOD_POST, WD_AI_TRGSRC_ExtD,
1047:                             WD_AI_TrgPositive, 0, 0.0, 0, 0, 0, 1);
1048:     if (err != NoError) return 0;
1049:     WD_AI_AsyncDblBufferMode(adcCard, 1);
1050:     WD_AI_ContBufferSetup(adcCard, dmaBuffer1, halfBufferSize, &adcBufId);
1051:     WD_AI_ContBufferSetup(adcCard, dmaBuffer2, halfBufferSize, &adcBufId);
1052:     CmtNewTSQ(20, halfBufferSize * sizeof(U16), OPT_TSQ_DYNAMIC_SIZE, &dmaQueue);
1053:     isAcquiring = 1;
1054:     adcRunning = 1;
1055:     CmtScheduleThreadPoolFunction(DEFAULT_THREAD_POOL_HANDLE, DiskWriterThreadFunction, NULL, &consumerThreadID);
1056:     CmtScheduleThreadPoolFunction(DEFAULT_THREAD_POOL_HANDLE, HardwarePollThreadFunction, NULL, &producerThreadID);
1057:     err = WD_AI_ContScanChannels(adcCard, 1, adcBufId, totalScansPerCh, 1, 1, ASYNCH_OP);
1058:     if (err == NoError) {
1059:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Acquisition Armed [Dual-Buffer Polled]");
1060:         SetCtrlAttribute(adcTabHandle, TABPANEL_2_ADC_BTN_START_ACQ, ATTR_DIMMED, 1);
1061:         SetCtrlAttribute(adcTabHandle, TABPANEL_2_ADC_BTN_STOP_ACQ,  ATTR_DIMMED, 0);
1062:     } else {
1063:         AdcStopCB(0, 0, EVENT_COMMIT, NULL, 0, 0);
1064:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Execution Failed");
1065:     }
1066:     return 0;
1067: }
1068: int CVICALLBACK AdcSingleShotCB (int p, int c, int ev, void *cbd, int e1, int e2)
1069: {
1070:     I16 err;
1071:     U16 chans[2] = {0, 1};
1072:     U32 totalScans, totalSamples;
1073:     U16 *diagBuffer = NULL;
1074:     U16 diagBufId;
1075:     BOOLEAN bStopped = FALSE;
1076:     U32 accessCnt = 0;
1077:     double startT;
1078:     if (ev != EVENT_COMMIT || !adcRegistered) return 0;
1079:     GetCtrlVal(adcTabHandle, TABPANEL_2_ADC_NUM_SAMP_PER_TRIG, &samplesPerChirp);
1080:     if (samplesPerChirp == 0) return 0;
1081:     totalScans = samplesPerChirp;
1082:     totalSamples = totalScans * ADC_NUM_CHANNELS;
1083:     diagBuffer = (U16 *)WD_Buffer_Alloc(adcCard, totalSamples * sizeof(U16));
1084:     if (!diagBuffer) {
1085:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Diag Memory Alloc Failed");
1086:         return 0;
1087:     }
1088:     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Waiting for Hardware Trigger (Max 5s)...");
1089:     ProcessSystemEvents();
1090:     WD_AI_AsyncDblBufferMode(adcCard, 0);
1091:     WD_AI_ContBufferReset(adcCard);
1092:     err = WD_AI_ContBufferSetup(adcCard, diagBuffer, totalSamples, &diagBufId);
1093:     err = WD_AI_Trig_Config(adcCard, WD_AI_TRGMOD_POST, WD_AI_TRGSRC_ExtD,
1094:                              WD_AI_TrgPositive, 0, 0.0, 0, 0, 0, 1);
1095:     err = WD_AI_ContReadMultiChannels(adcCard, ADC_NUM_CHANNELS, chans, diagBufId, totalScans, 1, 1, ASYNCH_OP);
1096:     if (err == NoError) {
1097:         startT = Timer();
1098:         while (!bStopped && (Timer() - startT < 5.0)) {
1099:             WD_AI_AsyncCheck(adcCard, &bStopped, &accessCnt);
1100:             ProcessSystemEvents();
1101:             Sleep(10);
1102:         }
1103:         if (!bStopped) {
1104:             WD_AI_AsyncClear(adcCard, &accessCnt, &accessCnt);
1105:             SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Single-shot TIMEOUT: No Ext Trigger");
1106:         } else {
1107:             SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Single-shot captured OK");
1108:             plotBusy = 1;
1109:             memcpy(plotBuffer, diagBuffer, totalSamples * sizeof(U16));
1110:             plotSamples = samplesPerChirp;
1111:             PostDeferredCall((DeferredCallbackPtr)ADC_PlotFFT_Deferred, NULL);
1112:             {
1113:                 int saveChoice = ConfirmPopup("Save Single Shot",
1114:                     "Save this capture to a binary file for MATLAB post-processing?");
1115:                 if (saveChoice == 1) {
1116:                     char savePath[MAX_PATHNAME_LEN];
1117:                     int sel = FileSelectPopup("", "*.bin", "Binary Data (*.bin)",
1118:                                               "Save Single-Shot Data",
1119:                                               VAL_SAVE_BUTTON, 0, 0, 1, 1, savePath);
1120:                     if (sel != VAL_NO_FILE_SELECTED) {
1121:                         FILE *fp = fopen(savePath, "wb");
1122:                         if (fp) {
1123:                             RadarFileHeader hdr;
1124:                             double startF, stopF, period;
1125:                             GetCtrlVal(ddsTabHandle, TABPANEL_DDS_NUM_START_FREQ, &startF);
1126:                             GetCtrlVal(ddsTabHandle, TABPANEL_DDS_NUM_STOP_FREQ,  &stopF);
1127:                             GetCtrlVal(ddsTabHandle, TABPANEL_DDS_NUM_PERIOD,      &period);
1128:                             memset(&hdr, 0, sizeof(hdr));
1129:                             hdr.magic               = RADAR_FILE_MAGIC;
1130:                             hdr.num_channels        = ADC_NUM_CHANNELS;
1131:                             hdr.samples_per_trigger = samplesPerChirp;
1132:                             hdr.num_triggers        = 1;
1133:                             hdr.sample_rate_hz      = currentAdcSampleRateHz;
1134:                             hdr.dds_start_freq_hz   = startF * 1e6;
1135:                             hdr.dds_stop_freq_hz    = stopF  * 1e6;
1136:                             hdr.dds_sweep_period_us = period;
1137:                             fwrite(&hdr, sizeof(hdr), 1, fp);
1138:                             fwrite(diagBuffer, sizeof(U16), totalSamples, fp);
1139:                             fclose(fp);
1140:                             SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Single-shot saved OK");
1141:                         }
1142:                     }
1143:                 }
1144:             }
1145:         }
1146:     } else {
1147:         char msg[128];
1148:         sprintf(msg, "Single-shot execution error: %d", err);
1149:         SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, msg);
1150:     }
1151:     WD_AI_ContBufferReset(adcCard);
1152:     WD_Buffer_Free(adcCard, diagBuffer);
1153:     return 0;
1154: }
1155: int CVICALLBACK AdcStopCB (int p, int c, int ev, void *cbd, int e1, int e2)
1156: {
1157:     if (ev != EVENT_COMMIT) return 0;
1158:     isAcquiring = 0;
1159:     adcRunning = 0;
1160:     if (producerThreadID != 0) {
1161:         CmtWaitForThreadPoolFunctionCompletion(DEFAULT_THREAD_POOL_HANDLE, producerThreadID, 0);
1162:         CmtReleaseThreadPoolFunctionID(DEFAULT_THREAD_POOL_HANDLE, producerThreadID);
1163:         producerThreadID = 0;
1164:     }
1165:     if (consumerThreadID != 0) {
1166:         CmtWaitForThreadPoolFunctionCompletion(DEFAULT_THREAD_POOL_HANDLE, consumerThreadID, 0);
1167:         CmtReleaseThreadPoolFunctionID(DEFAULT_THREAD_POOL_HANDLE, consumerThreadID);
1168:         consumerThreadID = 0;
1169:     }
1170:     if (dmaQueue != 0) {
1171:         CmtDiscardTSQ(dmaQueue);
1172:         dmaQueue = 0;
1173:     }
1174:     if (adcCard >= 0) {
1175:         U32 d1, d2;
1176:         WD_AI_AsyncClear(adcCard, &d1, &d2);
1177:         WD_AI_AsyncDblBufferMode(adcCard, 0);
1178:         WD_AI_ContBufferReset(adcCard);
1179:     }
1180:     if (recording) {
1181:         ADC_RecordFinish();
1182:         recording = 0;
1183:     }
1184:     SetCtrlVal(adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Acquisition stopped cleanly");
1185:     SetCtrlAttribute(adcTabHandle, TABPANEL_2_ADC_BTN_START_ACQ, ATTR_DIMMED, 0);
1186:     SetCtrlAttribute(adcTabHandle, TABPANEL_2_ADC_BTN_STOP_ACQ,  ATTR_DIMMED, 1);
1187:     ADC_PlotFFT_Deferred(NULL);
1188:     return 0;
1189: }
1190: int CVICALLBACK AdcReleaseCB (int p, int c, int ev, void *cbd, int e1, int e2)
1191: {
1192:     if (ev != EVENT_COMMIT) return 0;
1193:     if (isAcquiring || adcRunning || recording) {
1194:         AdcStopCB(0, 0, EVENT_COMMIT, NULL, 0, 0);
1195:     }
1196:     if (dmaBuffer1) {
1197:         WD_Buffer_Free(adcCard, dmaBuffer1);
1198:         dmaBuffer1 = NULL;
1199:     }
1200:     if (dmaBuffer2) {
1201:         WD_Buffer_Free(adcCard, dmaBuffer2);
1202:         dmaBuffer2 = NULL;
1203:     }
1204:     if (adcCard >= 0) {
1205:         WD_AI_ContBufferReset(adcCard);
1206:         WD_Release_Card(adcCard);
1207:         adcCard = -1;
1208:     }
1209:     adcRegistered = 0;
1210:     SetCtrlVal (adcTabHandle, TABPANEL_2_ADC_MSG_STATUS, "Card released");
1211:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_REGISTER,  ATTR_DIMMED, 0);
1212:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_CONFIGURE, ATTR_DIMMED, 1);
1213:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_START_ACQ, ATTR_DIMMED, 1);
1214:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_STOP_ACQ,  ATTR_DIMMED, 1);
1215:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_RELEASE,   ATTR_DIMMED, 1);
1216:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_SAVE,      ATTR_DIMMED, 1);
1217:     SetCtrlAttribute (adcTabHandle, TABPANEL_2_ADC_BTN_RECORD,    ATTR_DIMMED, 1);
1218:     return 0;
1219: }
