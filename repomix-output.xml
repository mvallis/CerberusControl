 164: static void ScanVISAResources (void)
 165: {
 166:     ViFindList findList;
 167:     ViUInt32   numFound;
 168:     ViChar     desc[RESOURCE_STR_LEN];
 169:     char       displayStr[RESOURCE_STR_LEN + 64];
 170:     ViStatus   status;
 171:     numResources = 0;
 172:     ClearListCtrl (relayTabHandle, RELAY_TAB_RELAY_RING_RESOURCE);
 173:     ClearListCtrl (psuTabHandle,   PSU_TAB_PSU_RING_RESOURCE);
 174:     if (defaultRM == VI_NULL) return;
 175:     status = viFindRsrc (defaultRM, "?*INSTR", &findList, &numFound, desc);
 176:     if (status < VI_SUCCESS || numFound == 0) return;
 177:     do {
 178:         strncpy (resourceList[numResources], desc, RESOURCE_STR_LEN - 1);
 179:         if (strstr(desc, "ASRL18::INSTR") != NULL)
 180:         {
 181:             sprintf(displayStr, "%s (KMTronic USB Relay)", desc);
 182:         }
 183:         else if (strstr(desc, "USB") != NULL && strstr(desc, "::INSTR") != NULL)
 184:         {
 185:             sprintf(displayStr, "%s (Siglent SPD3303X)", desc);
 186:         }
 187:         else
 188:         {
 189:             strcpy(displayStr, desc);
 190:         }
 191:         InsertListItem (relayTabHandle, RELAY_TAB_RELAY_RING_RESOURCE, -1, displayStr, numResources);
 192:         InsertListItem (psuTabHandle,   PSU_TAB_PSU_RING_RESOURCE,   -1, displayStr, numResources);
 193:         numResources++;
 194:     } while (numResources < (int)numFound && numResources < MAX_RESOURCES &&
 195:              viFindNext (findList, desc) == VI_SUCCESS);
 196:     viClose (findList);
 197: }
