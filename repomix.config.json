{
  "$schema": "https://repomix.com/repomix-config.schema.json",
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "copyToClipboard": false,
    "headerText": "CerberusControl Project - CVI/MATLAB Technical Context"
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "cvibuild.*/",
      "*.obj",
      "*.res",
      "*.exe",
      "*.dll",
      "*.lib",
      "*.cws",
      "*.cdb",
      "*.asv",
      "*.slxc",
      "slprj/",
      ".claude/",
      "mcp_config.json",
      "repomix-output.xml",
      "repomix-output.txt"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  }
}